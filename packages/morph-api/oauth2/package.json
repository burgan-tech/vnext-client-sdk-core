{
  "name": "@morph/oauth2",
  "version": "0.1.0",
  "description": "Morph OAuth2 plugin — token lifecycle, vault, and OAuth helpers",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",

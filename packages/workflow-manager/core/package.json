{
  "name": "amorphie-workflow-manager",
  "version": "0.1.0",
  "description": "Amorphie low-code workflow runtime client SDK — non-visual, framework-agnostic",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "format": "prettier --write src tests"
  },
  "peerDependencies": {
    "@morph/core": "*"
  },
  "peerDependenciesMeta": {
    "@morph/core": {
      "optional": false
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@morph/core": "file:../../../morph-api-client/packages/ts/core",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "happy-dom": "^15.11.7",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "sideEffects": false,
  "license": "UNLICENSED",
  "dependencies": {
    "@eslint/js": "^9.39.4"
  }
}
